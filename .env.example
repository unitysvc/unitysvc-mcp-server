# Bind address for the streamable-http transport. Leave as loopback locally;
# the Docker image sets 0.0.0.0 so the container is reachable.
# UNITYSVC_MCP_HOST=127.0.0.1
# UNITYSVC_MCP_PORT=8000

# Anonymous public catalog. This is the site host, whose ingress peels /v1/*
# to the `frontend` BFF deployment — the only one that mounts the catalog
# routes unauthenticated. Not the same host as the customer API below.
UNITYSVC_PUBLIC_API_URL=https://unitysvc.com/v1

# Customer API base (DEPLOYMENT_TYPE=customer). Every route here requires
# customer auth. For a local dedicated customer backend this is often:
# http://localhost:8000/v1
UNITYSVC_CUSTOMER_API_URL=https://api.unitysvc.com/v1

# Seller API base. For staging this may be:
# https://seller.staging.unitysvc.com/v1
UNITYSVC_SELLER_API_URL=https://seller.unitysvc.com/v1

# Optional OAuth/OIDC token introspection endpoint. If unset, bearer tokens are
# passed through to UnitySVC APIs and only development tokens below are decoded.
# UNITYSVC_AUTH_INTROSPECTION_URL=https://keycloak.example.com/realms/unitysvc/protocol/openid-connect/token/introspect
# UNITYSVC_AUTH_INTROSPECTION_CLIENT_ID=unitysvc-mcp
# UNITYSVC_AUTH_INTROSPECTION_CLIENT_SECRET=...

# Development-only token map. Keys are bearer tokens; values become principals.
# Example:
# {"dev-customer":{"subject":"u_1","roles":["customer"],"customer_id":"c_1"},"dev-seller":{"subject":"u_2","roles":["seller"],"seller_id":"s_1"}}
UNITYSVC_MCP_DEV_TOKENS={}

# Optional default group for authenticated customer catalog listing.
# If unset, listing falls back to the platform-wide `all_services` collection.
# Ignored for anonymous callers, whose catalog listing is not group-scoped.
# UNITYSVC_DEFAULT_CATALOG_GROUP=llm
