# Public/customer API base. For local dedicated customer backend this is often:
# http://localhost:8000/v1
UNITYSVC_CUSTOMER_API_URL=https://customer.unitysvc.com/v1

# Seller API base. For staging this may be:
# https://seller.staging.unitysvc.com/v1
UNITYSVC_SELLER_API_URL=https://seller.unitysvc.com/v1

# Optional OAuth/OIDC token introspection endpoint. If unset, bearer tokens are
# passed through to UnitySVC APIs and only development tokens below are decoded.
# UNITYSVC_AUTH_INTROSPECTION_URL=https://keycloak.example.com/realms/unitysvc/protocol/openid-connect/token/introspect
# UNITYSVC_AUTH_INTROSPECTION_CLIENT_ID=unitysvc-mcp
# UNITYSVC_AUTH_INTROSPECTION_CLIENT_SECRET=...

# Development-only token map. Keys are bearer tokens; values become principals.
# Example:
# {"dev-customer":{"subject":"u_1","roles":["customer"],"customer_id":"c_1"},"dev-seller":{"subject":"u_2","roles":["seller"],"seller_id":"s_1"}}
UNITYSVC_MCP_DEV_TOKENS={}

# Optional default group used by anonymous/customer list_services.
# If unset, the server lists groups first and pulls services from visible groups.
# UNITYSVC_DEFAULT_CATALOG_GROUP=llm
