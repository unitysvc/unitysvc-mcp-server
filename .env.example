# ---------------------------------------------------------------------------
# Credentials — the ONLY thing that decides which tools this server offers.
#
# Presence is the role signal: svcpass_ keys already encode customer/seller,
# and the backend authorises every call from the key. Leave both unset for a
# context-only (anonymous) server — that is exactly how the hosted deployment
# at mcp.unitysvc.com runs.
#
# NOTE: exporting these in your shell does NOT reach a stdio MCP server. MCP
# clients pass only a safelist (HOME/LOGNAME/PATH/SHELL/TERM/USER), so they
# must be declared in your MCP client config. See the README.
# ---------------------------------------------------------------------------
# UNITYSVC_SELLER_API_KEY=svcpass_...
# Customer key — unlocks the customer_* tools (your secrets/enrollments joined
# onto the access plan). Anonymous browsing works without it.
# UNITYSVC_API_KEY=svcpass_...
# How long (seconds) a customer_* tool caches your context snapshot.
# UNITYSVC_CUSTOMER_CONTEXT_TTL=300

# ---------------------------------------------------------------------------
# Backends. Names match the SDKs' own, so if you already use the `usvc` CLI
# these are set and need no new values.
# ---------------------------------------------------------------------------
UNITYSVC_API_URL=https://api.unitysvc.com/v1
UNITYSVC_SELLER_API_URL=https://seller.unitysvc.com/v1

# The frontend site that serves the docs "topics" (/topics, /topics/<slug>)
# the docs_* tools read. Public — no credential.
# UNITYSVC_SITE_URL=https://unitysvc.com
# How long (seconds) the docs_* tools cache a fetched manifest/topic.
# UNITYSVC_DOCS_CACHE_TTL=900

# ---------------------------------------------------------------------------
# Transport. `stdio` (default) runs as a subprocess of your MCP client.
# `http` is for the hosted deployment; host/port apply to it only.
# ---------------------------------------------------------------------------
# UNITYSVC_MCP_TRANSPORT=stdio
# UNITYSVC_MCP_HOST=127.0.0.1
# UNITYSVC_MCP_PORT=8000

# Optional default group for catalog listing (discovery is group-rooted).
# Unset falls back to the platform-wide `all_services` collection.
# UNITYSVC_DEFAULT_CATALOG_GROUP=llm
